# OpenClaw: never commit secrets or local config
openclaw.json
~/.openclaw/
*.env
*.local.json
*.secret
*.bak
*.swp
*.log
*.pyc
.DS_Store
keys.md

# Node.js
node_modules/
package-lock.json

# TypeScript build output
dist/

# Runtime data
data/

# Python virtual environment
.venv/
__pycache__/

# OpenClaw runtime state (создаётся автоматически в каждом workspace)
**/.openclaw/

# OpenClaw auto-generated templates (можно добавить, если полезны)
# USER.md
# HEARTBEAT.md
skills/taskboard/data/telegram.conf

# Claude Code — авто-память (per-machine, не шарить)
.claude/memory/

# skills.sh — загружаемые скилы (аналог node_modules, не коммитить)
# Для установки:
#   npx skills add https://github.com/antfu/skills --skill vitest --yes
#   npx skills add https://github.com/github/awesome-copilot --skill git-commit --yes
#   npx skills add https://github.com/wshobson/agents --skill typescript-advanced-types --yes
.agents/
